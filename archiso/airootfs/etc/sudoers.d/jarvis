# Jarvis OS — sudoers configuration
# The 'jarvis' user and 'wheel' group have full sudo access.

Defaults env_reset
Defaults mail_badpass
Defaults !visiblepw
Defaults always_query_group_plugin
Defaults secure_path="/usr/local/sbin:/usr/local/bin:/usr/bin:/usr/sbin:/sbin:/bin"

# Root can run anything
root ALL=(ALL:ALL) ALL

# Wheel group has full sudo
%wheel ALL=(ALL:ALL) ALL

# Jarvis user has full sudo (no password for system management)
jarvis ALL=(ALL:ALL) NOPASSWD: ALL

# Allow Jarvis to manage services without password
jarvis ALL=(ALL) NOPASSWD: /usr/bin/systemctl, /usr/bin/journalctl, /usr/bin/pacman, /usr/bin/mkarchiso
