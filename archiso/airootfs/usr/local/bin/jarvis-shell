#!/usr/bin/env bash
# jarvis-shell — launches Jarvis Desktop as the desktop shell
# Replaces GNOME/KDE/XFCE as the primary desktop environment.
#
# This script is called by SDDM (display manager) on login.
# It sets up the environment, starts the display server, and
# launches Jarvis in shell mode.

set -euo pipefail

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-x11}"
export XDG_CURRENT_DESKTOP="jarvis"
export XDG_SESSION_DESKTOP="jarvis"
export DESKTOP_SESSION="jarvis"
export GTK_THEME="Adwaita:dark"
export QT_QPA_PLATFORMTHEME="qt5ct"
export SDL_VIDEODRIVER="wayland,x11"

# ── Start D-Bus session bus ──────────────────────────────────
if ! dbus-launch --sh-syntax --exit-with-session >/dev/null 2>&1; then
    echo "Warning: dbus-launch failed" >&2
fi

# ── Start PipeWire (audio) ───────────────────────────────────
if command -v pipewire >/dev/null 2>&1; then
    pipewire &
    sleep 0.5
    wireplumber &
    pipewire-pulse &
fi

# ── Start BlueZ (Bluetooth) ──────────────────────────────────
if command -v bluetoothctl >/dev/null 2>&1; then
    bluetoothctl power on 2>/dev/null || true
fi

# ── Start NetworkManager applet ──────────────────────────────
nm-applet --sm-disable --disable-connected-notification 2>/dev/null &

# ── Start Polkit (authentication agent) ──────────────────────
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 2>/dev/null &

# ── Start GNOME Keyring (secret storage) ─────────────────────
gnome-keyring-daemon --start --components=secrets,pkcs11 2>/dev/null &

# ── Start xdg-desktop-portal ─────────────────────────────────
xdg-desktop-portal --replace 2>/dev/null &
xdg-desktop-portal-gtk 2>/dev/null &

# ── Set up X resources ───────────────────────────────────────
if [ -n "${DISPLAY:-}" ]; then
    xrdb -merge /etc/X11/xinit/.Xresources 2>/dev/null || true
    xset s off 2>/dev/null || true        # disable screensaver
    xset -dpms 2>/dev/null || true        # disable DPMS
    xset s noblank 2>/dev/null || true
fi

# ── Find Jarvis executable ───────────────────────────────────
JARVIS_BIN=""
for candidate in \
    /usr/bin/jarvis \
    /usr/local/bin/jarvis \
    /opt/jarvis/jarvis \
    "$HOME/.local/bin/jarvis" \
    "$(command -v jarvis 2>/dev/null)"
do
    if [ -x "$candidate" ]; then
        JARVIS_BIN="$candidate"
        break
    fi
done

if [ -z "$JARVIS_BIN" ]; then
    echo "ERROR: Jarvis executable not found." >&2
    echo "Install Jarvis: sudo pacman -S jarvis-desktop" >&2
    # Fall back to a minimal terminal so the user can troubleshoot
    if command -v xterm >/dev/null 2>&1; then
        exec xterm -e "echo 'Jarvis not found. Install with: sudo pacman -S jarvis-desktop'; bash"
    elif command -v alacritty >/dev/null 2>&1; then
        exec alacritty -e bash
    fi
    exit 1
fi

# ── Launch Jarvis in shell mode ──────────────────────────────
# --shell replaces the desktop (no taskbar, no window manager
# decorations — Jarvis IS the window manager + desktop)
exec "$JARVIS_BIN" --shell
