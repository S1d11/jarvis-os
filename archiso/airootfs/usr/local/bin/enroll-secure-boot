#!/usr/bin/env bash
# enroll-secure-boot — Set up Secure Boot for Jarvis OS
#
# This script:
#   1. Generates a Platform Key (PK), Key Exchange Key (KEK), and
#      database key (db) if they don't exist
#   2. Signs the Jarvis OS kernel and bootloader with these keys
#   3. Enrolls the keys into the UEFI firmware
#   4. Optionally enrolls Microsoft's keys (for dual-boot compatibility)
#
# Requirements:
#   - UEFI firmware with Secure Boot support
#   - sbctl (Secure Boot Manager)
#   - mokutil
#   - efitools

set -euo pipefail

KEYS_DIR="/etc/secureboot/keys"
EFI_DIR="/boot/EFI"

echo "=========================================="
echo "  Jarvis OS — Secure Boot Enrollment"
echo "=========================================="
echo ""

# ── Check if we're in UEFI mode ──────────────────────────────
if [ ! -d /sys/firmware/efi ]; then
    echo "ERROR: System is not booted in UEFI mode." >&2
    echo "Reboot with UEFI mode enabled in firmware settings." >&2
    exit 1
fi

# ── Check if Secure Boot is already enabled ──────────────────
SB_STATUS=$(mokutil --sb-state 2>/dev/null || echo "unknown")
echo "Current Secure Boot status: $SB_STATUS"
echo ""

# ── Use sbctl for key management ─────────────────────────────
if ! command -v sbctl >/dev/null 2>&1; then
    echo "ERROR: sbctl not installed. Run: sudo pacman -S sbctl" >&2
    exit 1
fi

# ── Create signing keys ──────────────────────────────────────
echo "[1/5] Creating Secure Boot signing keys..."
sbctl create-keys 2>/dev/null || {
    echo "  Keys already exist or creation failed."
}
echo "  Keys stored in: $KEYS_DIR"
echo ""

# ── Sign the kernel ──────────────────────────────────────────
echo "[2/5] Signing kernel..."
KERNEL_IMG="/boot/vmlinuz-linux"
if [ -f "$KERNEL_IMG" ]; then
    sbctl sign -s "$KERNEL_IMG"
    echo "  Signed: $KERNEL_IMG"
else
    echo "  WARNING: Kernel not found at $KERNEL_IMG"
fi
echo ""

# ── Sign the bootloader (GRUB) ───────────────────────────────
echo "[3/5] Signing GRUB bootloader..."
GRUB_EFI=""
for efi in \
    "$EFI_DIR/EFI/jarvis/grubx64.efi" \
    "$EFI_DIR/EFI/GRUB/grubx64.efi" \
    "$EFI_DIR/EFI/systemd/systemd-bootx64.efi" \
    "/boot/efi/EFI/jarvis/grubx64.efi"
do
    if [ -f "$efi" ]; then
        GRUB_EFI="$efi"
        break
    fi
done

if [ -n "$GRUB_EFI" ]; then
    sbctl sign -s "$GRUB_EFI"
    echo "  Signed: $GRUB_EFI"
else
    echo "  WARNING: No bootloader EFI found to sign."
fi
echo ""

# ── Enroll keys into firmware ────────────────────────────────
echo "[4/5] Enrolling keys into UEFI firmware..."
echo ""
echo "  Options:"
echo "    1) Enroll Jarvis OS keys only (most secure, no dual-boot)"
echo "    2) Enroll Jarvis OS keys + Microsoft keys (dual-boot compatible)"
echo "    3) Enroll Jarvis OS keys + Microsoft keys + your own key"
echo ""
read -r -p "Choose option [1-3]: " enroll_option

case "$enroll_option" in
    1)
        sbctl enroll-keys --microsoft false
        ;;
    2)
        sbctl enroll-keys --microsoft true
        ;;
    3)
        sbctl enroll-keys --microsoft true --custom /path/to/your/key.pem
        ;;
    *)
        echo "Invalid option. Aborting." >&2
        exit 1
        ;;
esac

echo "  Keys enrolled successfully."
echo ""

# ── Verify ───────────────────────────────────────────────────
echo "[5/5] Verifying Secure Boot setup..."
sbctl verify
echo ""

echo "=========================================="
echo "  Secure Boot enrollment complete!"
echo "=========================================="
echo ""
echo "Reboot your computer. Secure Boot will be active."
echo "The Jarvis OS kernel and bootloader are signed and will boot."
echo ""
echo "To verify after reboot:"
echo "  mokutil --sb-state        # Should say: SecureBoot enabled"
echo "  sbctl verify              # Should show all signatures valid"
echo ""
