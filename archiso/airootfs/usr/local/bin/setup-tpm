#!/usr/bin/env bash
# setup-tpm — Initialize and configure TPM 2.0 for Jarvis OS
#
# This script:
#   1. Checks for TPM 2.0 hardware
#   2. Starts the TPM2 resource manager (tpm2-abrmd)
#   3. Initializes the TPM
#   4. Enables disk encryption with TPM-backed sealing
#   5. Registers the TPM as a Platform Configuration Register (PCR) source

set -euo pipefail

echo "=========================================="
echo "  Jarvis OS — TPM 2.0 Setup"
echo "=========================================="
echo ""

# ── Check for TPM 2.0 hardware ───────────────────────────────
if ! ls /dev/tpm* /dev/tpmrm* 2>/dev/null | head -1 | grep -q .; then
    echo "ERROR: No TPM device found." >&2
    echo "Ensure TPM 2.0 is enabled in UEFI/BIOS firmware settings." >&2
    exit 1
fi

TPM_DEV=""
for dev in /dev/tpmrm0 /dev/tpm0; do
    if [ -e "$dev" ]; then
        TPM_DEV="$dev"
        break
    fi
done
echo "TPM device: $TPM_DEV"

# ── Load TPM 2.0 kernel modules ──────────────────────────────
modprobe tpm_tis 2>/dev/null || true
modprobe tpm_tis_core 2>/dev/null || true
modprobe tpm_crb 2>/dev/null || true
modprobe tpm2_ibm 2>/dev/null || true

# ── Start tpm2-abrmd (TPM2 Access Broker & Resource Manager) ──
if command -v tpm2-abrmd >/dev/null 2>&1; then
    systemctl enable tpm2-abrmd 2>/dev/null || true
    systemctl start tpm2-abrmd 2>/dev/null || true
    echo "Started tpm2-abrmd service."
fi

# ── Check TPM capabilities ───────────────────────────────────
echo ""
echo "TPM capabilities:"
tpm2_getcap properties-fixed 2>/dev/null | head -20 || echo "  (tpm2_getcap not available)"

# ── Read PCRs (Platform Configuration Registers) ─────────────
echo ""
echo "Current PCR values:"
for pcr in 0 1 2 3 4 5 6 7; do
    value=$(tpm2_pcrread sha256:"$pcr" 2>/dev/null | awk '{print $2}' | head -1 || echo "N/A")
    echo "  PCR-$pcr: $value"
done

# ── Enable kernel lockdown (confidentiality mode) ────────────
# This prevents userspace from accessing raw kernel memory,
# which is required for Secure Boot integrity.
echo ""
echo "Kernel lockdown mode:"
if [ -f /sys/kernel/security/lockdown ]; then
    cat /sys/kernel/security/lockdown
else
    echo "  (lockdown not available — Secure Boot may not be enabled)"
fi

echo ""
echo "=========================================="
echo "  TPM 2.0 setup complete!"
echo "=========================================="
echo ""
echo "To enable TPM-backed disk encryption:"
echo "  sudo cryptsetup luksFormat --tpm2-device=$TPM_DEV /dev/sdX"
echo ""
echo "To seal a LUKS key to PCR 7 (Secure Boot state):"
echo "  sudo cryptsetup luksAddKey --tpm2-device=$TPM_DEV --tpm2-pcrs=7 /dev/sdX"
echo ""
